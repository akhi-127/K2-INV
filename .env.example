# ============================================================
# K2 INVENTORY — ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to git.
# In Vercel: add these in Project Settings → Environment Variables
# ============================================================

# Supabase — get from supabase.com → Project Settings → API
# NOTE: We use the SERVICE ROLE key server-side only.
# The anon key is NOT used — all requests go through our API routes.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Session encryption — generate with: openssl rand -hex 32
# Must be at least 32 characters. Keep secret.
SESSION_SECRET=replace-with-32-char-random-string-here

# App URL — used for OAuth callback validation
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Google OAuth — configured in Supabase Auth settings
# These are set in Supabase dashboard, not here directly.
# Just ensure your Supabase project has Google OAuth enabled.

# Rate limiting (optional, defaults shown)
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW=60
